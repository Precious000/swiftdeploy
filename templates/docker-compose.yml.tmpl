services:
  nginx:
    image: __NGINX_IMAGE__
    ports:
      - "__NGINX_PORT__:__NGINX_PORT__"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - __LOGS_VOLUME__:/var/log/nginx
    networks:
      - __NETWORK_NAME__
    depends_on:
      app:
        condition: service_healthy
    restart: __RESTART_POLICY__

  app:
    image: __APP_IMAGE__
    environment:
      - MODE=__MODE__
      - APP_VERSION=__APP_VERSION__
      - APP_PORT=__APP_PORT__
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    user: "1000:1000"
    volumes:
      - __LOGS_VOLUME__:/app/logs
    networks:
      - __NETWORK_NAME__
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:__APP_PORT__/healthz')"]
      interval: 10s
      timeout: 5s
      retries: 6
      start_period: 10s
    restart: __RESTART_POLICY__

  opa:
    image: __OPA_IMAGE__
    command:
      - "run"
      - "--server"
      - "--addr=0.0.0.0:__OPA_PORT__"
      - "--log-level=error"
      - "/policies"
    volumes:
      - __POLICIES_DIR__:/policies:ro
    networks:
      - __NETWORK_NAME__
    restart: __RESTART_POLICY__
    ports:
    - "__OPA_PORT__:__OPA_PORT__"
networks:
  __NETWORK_NAME__:
    driver: __NETWORK_DRIVER__

volumes:
  __LOGS_VOLUME__:
