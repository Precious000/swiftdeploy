#!/usr/bin/env bash
set -euo pipefail

MANIFEST="manifest.yaml"
COMPOSE_FILE="docker-compose.yml"
NGINX_CONF="nginx.conf"
NGINX_TMPL="templates/nginx.conf.tmpl"
COMPOSE_TMPL="templates/docker-compose.yml.tmpl"
HISTORY_FILE="history.jsonl"

# ── helpers ───────────────────────────────────────────────────────────────────

get_manifest() {
    python3 -c "
import yaml, sys
with open('$MANIFEST') as f:
    data = yaml.safe_load(f)
keys = '$1'.split('.')
val = data
for k in keys:
    val = val[k]
print(val)
"
}

set_manifest() {
    local key_path="$1"
    local value="$2"
    python3 - "$key_path" "$value" << 'PY'
import yaml, sys
key_path, value = sys.argv[1], sys.argv[2]
with open("manifest.yaml") as f:
    data = yaml.safe_load(f)
keys = key_path.split(".")
obj = data
for k in keys[:-1]:
    obj = obj[k]
obj[keys[-1]] = value
with open("manifest.yaml", "w") as f:
    yaml.dump(data, f, default_flow_style=False)
PY
}

# ── OPA query helper ──────────────────────────────────────────────────────────

# Queries OPA and returns allow=true/false + violations
# Usage: query_opa "swiftdeploy/infra" '{"disk_free_gb": 50, "cpu_load": 0.5}'
query_opa() {
    local package="$1"
    local input_json="$2"
    local opa_port
    opa_port=$(get_manifest "opa.port")

    # Build OPA REST API URL
    # OPA endpoint: POST /v1/data/{package}
    local url="http://localhost:${opa_port}/v1/data/${package}"

    # Wrap input in OPA's required format
    local payload
    payload=$(python3 -c "
import json, sys
input_data = json.loads(sys.argv[1])
print(json.dumps({'input': input_data}))
" "$input_json")

    # Try to reach OPA - handle all failure modes differently
    local response
    local http_code

    if ! response=$(curl -sf \
        -X POST "$url" \
        -H "Content-Type: application/json" \
        -d "$payload" \
        --connect-timeout 5 \
        --max-time 10 \
        -w "\n%{http_code}" 2>/dev/null); then

        # OPA is unreachable
        echo '{"reachable": false, "error": "OPA container unreachable - is the stack running?"}'
        return 1
    fi

    # Split response body and HTTP code
    local body http_status
    body=$(echo "$response" | head -n -1)
    http_status=$(echo "$response" | tail -n 1)

    if [ "$http_status" != "200" ]; then
        echo "{\"reachable\": false, \"error\": \"OPA returned HTTP ${http_status}\"}"
        return 1
    fi

    # Extract allow and violations from OPA response
    python3 - "$body" << 'PY'
import json, sys
resp = json.loads(sys.argv[1])
result = resp.get("result", {})
allow = result.get("allow", False)
violations = list(result.get("violations", set()))
print(json.dumps({
    "reachable": True,
    "allow": allow,
    "violations": violations
}))
PY
}

# ── pre-deploy check ──────────────────────────────────────────────────────────

run_pre_deploy_checks() {
    echo "→ Running pre-deploy policy checks..."

    # Gather host stats
    local disk_free_gb cpu_load mem_free_gb
    disk_free_gb=$(df / | awk 'NR==2 {printf "%.1f", $4/1024/1024}')
    cpu_load=$(awk '{print $1}' /proc/loadavg)
    mem_free_gb=$(awk '/MemAvailable/ {printf "%.1f", $2/1024/1024}' /proc/meminfo)

    local input_json
    input_json=$(python3 -c "
import json
print(json.dumps({
    'disk_free_gb': float('${disk_free_gb}'),
    'cpu_load': float('${cpu_load}'),
    'mem_free_gb': float('${mem_free_gb}'),
    'check_type': 'pre_deploy'
}))
")

    echo "  Host stats: disk=${disk_free_gb}GB free, cpu_load=${cpu_load}, mem=${mem_free_gb}GB free"

    local result
    if ! result=$(query_opa "swiftdeploy/infra" "$input_json" 2>/dev/null); then
        echo "  ⚠ OPA unreachable — deploying without policy check (fail-open)"
        echo "  To enable policy enforcement, ensure the stack is running first"
        return 0
    fi

    local allow violations
    allow=$(echo "$result" | python3 -c "import json,sys; print(json.load(sys.stdin)['allow'])")
    violations=$(echo "$result" | python3 -c "
import json,sys
d = json.load(sys.stdin)
for v in d.get('violations', []):
    print('  ✗', v)
")

    if [ "$allow" = "True" ] || [ "$allow" = "true" ]; then
        echo "  ✓ Infrastructure policy: PASSED"
        return 0
    else
        echo "  ✗ Infrastructure policy: BLOCKED"
        echo "$violations"
        return 1
    fi
}

# ── pre-promote check ─────────────────────────────────────────────────────────

run_pre_promote_checks() {
    local target="$1"
    local current_mode
    current_mode=$(get_manifest "services.mode")

    echo "→ Running pre-promote policy checks for ${target}..."

    # Skip only if already stable AND promoting to stable
    if [ "$current_mode" != "canary" ] && [ "$target" != "canary" ]; then
        echo "  Already in stable mode — skipping canary safety checks"
        return 0
    fi

    local nginx_port
    nginx_port=$(get_manifest "nginx.port")

    # Scrape /metrics from the running app via Nginx
    local metrics_raw
    if ! metrics_raw=$(curl -sf "http://localhost:${nginx_port}/metrics" 2>/dev/null); then
        echo "  ⚠ Cannot reach /metrics — skipping canary policy check"
        return 0
    fi

    # Parse metrics to calculate error rate and P99 latency
    local input_json
    input_json=$(python3 - "$metrics_raw" << 'PY'
import sys, re, json

raw = sys.argv[1]

# Parse prometheus text format
def get_value(name, raw):
    for line in raw.split('\n'):
        if line.startswith(name + ' ') or ('{' not in name and name + '{' in line):
            try:
                return float(line.split()[-1])
            except:
                pass
    return 0.0

# Count total requests and errors
total = 0
errors = 0
for line in raw.split('\n'):
    if line.startswith('http_requests_total{'):
        val = float(line.split()[-1])
        total += val
        if 'status_code="5' in line:
            errors += val

error_rate = (errors / total) if total > 0 else 0.0

# Calculate P99 from histogram buckets for / path
buckets = {}
count_total = 0
for line in raw.split('\n'):
    if 'http_request_duration_seconds_bucket' in line and 'path="/"' in line:
        le_match = re.search(r'le="([^"]+)"', line)
        if le_match:
            le = le_match.group(1)
            val = float(line.split()[-1])
            if le != '+Inf':
                buckets[float(le)] = val
            else:
                count_total = val

p99_latency_ms = 500.0
if count_total > 0:
    target_count = count_total * 0.99
    sorted_buckets = sorted(buckets.items())
    for le, count in sorted_buckets:
        if count >= target_count:
            p99_latency_ms = le * 1000
            break

print(json.dumps({
    'error_rate': error_rate,
    'p99_latency_ms': p99_latency_ms,
    'total_requests': total,
    'check_type': 'pre_promote'
}))
PY
)

    echo "  Metrics: $(echo "$input_json" | python3 -c "
import json,sys
d=json.load(sys.stdin)
print(f'error_rate={d[\"error_rate\"]*100:.2f}%, p99={d[\"p99_latency_ms\"]:.0f}ms, total={d[\"total_requests\"]:.0f} reqs')
")"

    local result
    if ! result=$(query_opa "swiftdeploy/canary" "$input_json" 2>/dev/null); then
        echo "  ⚠ OPA unreachable — skipping canary policy check"
        return 0
    fi

    local allow violations
    allow=$(echo "$result" | python3 -c "import json,sys; print(json.load(sys.stdin)['allow'])")
    violations=$(echo "$result" | python3 -c "
import json,sys
d = json.load(sys.stdin)
for v in d.get('violations', []):
    print('  ✗', v)
")

    if [ "$allow" = "True" ] || [ "$allow" = "true" ]; then
        echo "  ✓ Canary safety policy: PASSED"
        return 0
    else
        echo "  ✗ Canary safety policy: BLOCKED"
        echo "$violations"
        return 1
    fi
}

# ── subcommand: init ──────────────────────────────────────────────────────────

cmd_init() {
    echo "→ Reading manifest.yaml..."

    APP_IMAGE=$(get_manifest "services.image")
    APP_PORT=$(get_manifest "services.port")
    APP_MODE=$(get_manifest "services.mode")
    APP_VERSION=$(get_manifest "services.version")
    APP_RESTART=$(get_manifest "services.restart_policy")

    NGINX_IMAGE=$(get_manifest "nginx.image")
    NGINX_PORT=$(get_manifest "nginx.port")
    PROXY_TIMEOUT=$(get_manifest "nginx.proxy_timeout")

    NET_NAME=$(get_manifest "network.name")
    NET_DRIVER=$(get_manifest "network.driver_type")
    LOGS_VOL=$(get_manifest "volumes.logs")

    OPA_IMAGE=$(get_manifest "opa.image")
    OPA_PORT=$(get_manifest "opa.port")
    POLICIES_DIR=$(get_manifest "opa.policies_dir")

    echo "→ Generating nginx.conf..."
    sed \
        -e "s|__NGINX_PORT__|${NGINX_PORT}|g" \
        -e "s|__APP_PORT__|${APP_PORT}|g" \
        -e "s|__PROXY_TIMEOUT__|${PROXY_TIMEOUT}|g" \
        -e "s|__SERVICE_NAME__|swiftdeploy-app|g" \
        "$NGINX_TMPL" > "$NGINX_CONF"

    echo "→ Generating docker-compose.yml..."
    sed \
        -e "s|__NGINX_IMAGE__|${NGINX_IMAGE}|g" \
        -e "s|__NGINX_PORT__|${NGINX_PORT}|g" \
        -e "s|__APP_IMAGE__|${APP_IMAGE}|g" \
        -e "s|__APP_PORT__|${APP_PORT}|g" \
        -e "s|__MODE__|${APP_MODE}|g" \
        -e "s|__APP_VERSION__|${APP_VERSION}|g" \
        -e "s|__NETWORK_NAME__|${NET_NAME}|g" \
        -e "s|__NETWORK_DRIVER__|${NET_DRIVER}|g" \
        -e "s|__LOGS_VOLUME__|${LOGS_VOL}|g" \
        -e "s|__RESTART_POLICY__|${APP_RESTART}|g" \
        -e "s|__OPA_IMAGE__|${OPA_IMAGE}|g" \
        -e "s|__OPA_PORT__|${OPA_PORT}|g" \
        -e "s|__POLICIES_DIR__|${POLICIES_DIR}|g" \
        "$COMPOSE_TMPL" > "$COMPOSE_FILE"

    echo "✓ init complete: nginx.conf and docker-compose.yml generated"
}

# ── subcommand: validate ──────────────────────────────────────────────────────

cmd_validate() {
    PASS=0; FAIL=0

    check() {
        local label="$1"; local result="$2"
        if [ "$result" = "pass" ]; then
            echo "  [PASS] $label"; PASS=$((PASS+1))
        else
            echo "  [FAIL] $label — $result"; FAIL=$((FAIL+1))
        fi
    }

    echo "Running pre-flight checks..."

    if [ -f "$MANIFEST" ] && python3 -c "import yaml; yaml.safe_load(open('$MANIFEST'))" 2>/dev/null; then
        check "manifest.yaml exists and is valid YAML" "pass"
    else
        check "manifest.yaml exists and is valid YAML" "file missing or invalid YAML"
    fi

    REQUIRED_FIELDS="services.image services.port nginx.image nginx.port network.name network.driver_type opa.image opa.port"
    FIELDS_OK=true; MISSING=""
    for field in $REQUIRED_FIELDS; do
        val=$(get_manifest "$field" 2>/dev/null || echo "")
        if [ -z "$val" ]; then FIELDS_OK=false; MISSING="$MISSING $field"; fi
    done
    if $FIELDS_OK; then
        check "All required fields present and non-empty" "pass"
    else
        check "All required fields present and non-empty" "missing:$MISSING"
    fi

    IMG=$(get_manifest "services.image" 2>/dev/null || echo "")
    if docker image inspect "$IMG" &>/dev/null; then
        check "Docker image '$IMG' exists locally" "pass"
    else
        check "Docker image '$IMG' exists locally" "image not found — run: docker build -t $IMG ."
    fi

    NGINX_PORT=$(get_manifest "nginx.port" 2>/dev/null || echo "")
    if ss -tlnp 2>/dev/null | grep -q ":${NGINX_PORT} "; then
        check "Nginx port ${NGINX_PORT} is free" "port already in use"
    else
        check "Nginx port ${NGINX_PORT} is free" "pass"
    fi

    if [ -f "$NGINX_CONF" ]; then
        NGINX_TEST=$(docker run --rm \
            -v "$(pwd)/${NGINX_CONF}:/etc/nginx/nginx.conf:ro" \
            nginx:latest nginx -t 2>&1 || true)
        if echo "$NGINX_TEST" | grep -q "syntax is ok"; then
            check "nginx.conf is syntactically valid" "pass"
        else
            check "nginx.conf is syntactically valid" "nginx -t reported errors"
        fi
    else
        echo "  → nginx.conf missing, running init first..."
        cmd_init > /dev/null 2>&1
        NGINX_TEST=$(docker run --rm \
            -v "$(pwd)/${NGINX_CONF}:/etc/nginx/nginx.conf:ro" \
            nginx:latest nginx -t 2>&1 || true)
        if echo "$NGINX_TEST" | grep -q "syntax is ok"; then
            check "nginx.conf is syntactically valid" "pass"
        else
            check "nginx.conf is syntactically valid" "nginx -t reported errors"
        fi
    fi

    echo ""
    echo "Result: ${PASS} passed, ${FAIL} failed"
    [ "$FAIL" -eq 0 ] || exit 1
}

# ── subcommand: deploy ────────────────────────────────────────────────────────

cmd_deploy() {
    cmd_init

    echo "→ Starting OPA first for policy checks..."
    docker compose up -d opa
    sleep 8

    # Gate: run OPA pre-deploy checks NOW (OPA is running)
    if ! run_pre_deploy_checks; then
        echo "✗ Deployment blocked by policy. Fix the violations above and retry."
        docker compose down
        exit 1
    fi

    echo "→ Starting remaining stack..."
    docker compose up -d

    echo "→ Waiting for health checks (timeout: 60s)..."
    NGINX_PORT=$(get_manifest "nginx.port")
    DEADLINE=$((SECONDS + 60))

    until curl -sf "http://localhost:${NGINX_PORT}/healthz" > /dev/null 2>&1; do
        if [ $SECONDS -ge $DEADLINE ]; then
            echo "✗ Health check timed out after 60 seconds"
            docker compose logs
            exit 1
        fi
        echo "  waiting..."
        sleep 3
    done

    python3 -c "
import json, time
event = {'timestamp': time.time(), 'event': 'deploy', 'mode': '$(get_manifest services.mode)'}
with open('$HISTORY_FILE', 'a') as f:
    f.write(json.dumps(event) + '\n')
"
    echo "✓ Stack is healthy and serving on port 8080"
}
# ── subcommand: promote ───────────────────────────────────────────────────────

cmd_promote() {
    local target="${1:-}"
    if [[ "$target" != "canary" && "$target" != "stable" ]]; then
        echo "Usage: ./swiftdeploy promote [canary|stable]"
        exit 1
    fi

    # Gate: run OPA pre-promote checks
    if ! run_pre_promote_checks "$target"; then
        echo "✗ Promotion blocked by policy. Fix the violations above and retry."
        exit 1
    fi

    echo "→ Promoting to ${target} mode..."
    set_manifest "services.mode" "$target"
    cmd_init
    docker compose up -d --no-deps app

    NGINX_PORT=$(get_manifest "nginx.port")
    echo "→ Confirming health after restart..."
    sleep 5
    RESPONSE=$(curl -sf "http://localhost:${NGINX_PORT}/healthz" || echo '{"status":"unreachable"}')
    echo "  /healthz response: $RESPONSE"

    if [ "$target" = "canary" ]; then
        HEADER=$(curl -sI "http://localhost:${NGINX_PORT}/" | grep -i "x-mode" || echo "none")
        echo "  X-Mode header: $HEADER"
    fi

    # Record promote event
    python3 -c "
import json, time
event = {'timestamp': time.time(), 'event': 'promote', 'mode': '${target}'}
with open('$HISTORY_FILE', 'a') as f:
    f.write(json.dumps(event) + '\n')
"
    echo "✓ Promoted to ${target}"
}

# ── subcommand: teardown ──────────────────────────────────────────────────────

cmd_teardown() {
    echo "→ Stopping and removing containers, networks, volumes..."
    docker compose down -v

    if [[ "${1:-}" == "--clean" ]]; then
        echo "→ --clean: removing generated configs..."
        rm -f "$COMPOSE_FILE" "$NGINX_CONF"
        echo "✓ Generated configs removed"
    fi

    echo "✓ Teardown complete"
}

# ── subcommand: status ────────────────────────────────────────────────────────

cmd_status() {
    local nginx_port opa_port
    nginx_port=$(get_manifest "nginx.port")
    opa_port=$(get_manifest "opa.port")

    echo "SwiftDeploy Status Dashboard"
    echo "============================="

    while true; do
        clear
        echo "SwiftDeploy Status — $(date '+%Y-%m-%d %H:%M:%S')"
        echo "================================================"

        # Scrape metrics
        local metrics_raw
        if ! metrics_raw=$(curl -sf "http://localhost:${nginx_port}/metrics" 2>/dev/null); then
            echo "✗ Cannot reach /metrics — is the stack running?"
            sleep 5
            continue
        fi

        # Parse and display metrics using Python
        python3 - "$metrics_raw" << 'PY'
import sys, re, json, time

raw = sys.argv[1]
lines = raw.split('\n')

total = 0; errors = 0
for line in lines:
    if line.startswith('http_requests_total{'):
        val = float(line.split()[-1])
        total += val
        if 'status_code="5' in line:
            errors += val

error_rate = (errors / total * 100) if total > 0 else 0.0

uptime = 0
mode_val = 0
chaos_val = 0
for line in lines:
    if line.startswith('app_uptime_seconds '):
        uptime = float(line.split()[-1])
    if line.startswith('app_mode '):
        mode_val = int(float(line.split()[-1]))
    if line.startswith('chaos_active '):
        chaos_val = int(float(line.split()[-1]))

mode_str = "canary" if mode_val == 1 else "stable"
chaos_map = {0: "none", 1: "slow", 2: "error"}
chaos_str = chaos_map.get(chaos_val, "unknown")

print(f"  Mode:        {mode_str}")
print(f"  Uptime:      {uptime:.0f}s")
print(f"  Total reqs:  {total:.0f}")
print(f"  Error rate:  {error_rate:.2f}%")
print(f"  Chaos:       {chaos_str}")
PY

        echo ""
        echo "Policy Compliance"
        echo "-----------------"

        # Check infra policy
        local disk_free_gb cpu_load
        disk_free_gb=$(df / | awk 'NR==2 {printf "%.1f", $4/1024/1024}')
        cpu_load=$(awk '{print $1}' /proc/loadavg)

        local infra_input
        infra_input=$(python3 -c "
import json
print(json.dumps({'disk_free_gb': float('${disk_free_gb}'), 'cpu_load': float('${cpu_load}'), 'check_type': 'status'}))
")
        local infra_result
        if infra_result=$(query_opa "swiftdeploy/infra" "$infra_input" 2>/dev/null); then
            local infra_allow
            infra_allow=$(echo "$infra_result" | python3 -c "import json,sys; print(json.load(sys.stdin)['allow'])")
            if [ "$infra_allow" = "True" ] || [ "$infra_allow" = "true" ]; then
                echo "  [PASS] Infrastructure policy"
            else
                echo "  [FAIL] Infrastructure policy"
                echo "$infra_result" | python3 -c "
import json,sys
for v in json.load(sys.stdin).get('violations', []):
    print('         ✗', v)
"
            fi
        else
            echo "  [WARN] Infrastructure policy — OPA unreachable"
        fi

        # Append to history.jsonl
        python3 - "$metrics_raw" "${disk_free_gb}" "${cpu_load}" << 'PY'
import sys, json, time

raw = sys.argv[1]
disk = float(sys.argv[2])
cpu = float(sys.argv[3])

total = 0; errors = 0
for line in raw.split('\n'):
    if line.startswith('http_requests_total{'):
        val = float(line.split()[-1])
        total += val
        if 'status_code="5' in line:
            errors += val

error_rate = (errors / total * 100) if total > 0 else 0.0

event = {
    'timestamp': time.time(),
    'event': 'scrape',
    'total_requests': total,
    'error_rate_pct': round(error_rate, 4),
    'disk_free_gb': disk,
    'cpu_load': cpu
}

with open('history.jsonl', 'a') as f:
    f.write(json.dumps(event) + '\n')
PY

        echo ""
        echo "  (refreshing every 5s — Ctrl+C to exit)"
        sleep 5
    done
}

# ── subcommand: audit ─────────────────────────────────────────────────────────

cmd_audit() {
    echo "→ Generating audit_report.md from ${HISTORY_FILE}..."

    if [ ! -f "$HISTORY_FILE" ]; then
        echo "✗ No history.jsonl found. Run ./swiftdeploy status first to collect data."
        exit 1
    fi

    python3 - "$HISTORY_FILE" << 'PY'
import json, sys
from datetime import datetime

history_file = sys.argv[1]
events = []
with open(history_file) as f:
    for line in f:
        line = line.strip()
        if line:
            events.append(json.loads(line))

report = []
report.append("# SwiftDeploy Audit Report")
report.append(f"\nGenerated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")

report.append("## Timeline\n")
report.append("| Time | Event | Details |")
report.append("|------|-------|---------|")

for e in events:
    ts = datetime.fromtimestamp(e['timestamp']).strftime('%Y-%m-%d %H:%M:%S')
    event = e.get('event', 'unknown')
    if event == 'deploy':
        detail = f"Deployed in `{e.get('mode', '?')}` mode"
    elif event == 'promote':
        detail = f"Promoted to `{e.get('mode', '?')}` mode"
    elif event == 'scrape':
        detail = f"error_rate={e.get('error_rate_pct', 0):.2f}%, disk={e.get('disk_free_gb', 0):.1f}GB"
    else:
        detail = str(e)
    report.append(f"| {ts} | {event} | {detail} |")

report.append("\n## Policy Violations\n")
violations_found = False
for e in events:
    if e.get('event') == 'scrape':
        if e.get('error_rate_pct', 0) > 1.0:
            ts = datetime.fromtimestamp(e['timestamp']).strftime('%Y-%m-%d %H:%M:%S')
            report.append(f"- **{ts}**: Error rate exceeded threshold: {e['error_rate_pct']:.2f}%")
            violations_found = True
        if e.get('disk_free_gb', 999) < 10:
            ts = datetime.fromtimestamp(e['timestamp']).strftime('%Y-%m-%d %H:%M:%S')
            report.append(f"- **{ts}**: Disk below threshold: {e['disk_free_gb']:.1f}GB free")
            violations_found = True

if not violations_found:
    report.append("_No policy violations recorded._")

report.append("\n## Summary\n")
deploys = len([e for e in events if e.get('event') == 'deploy'])
promotes = len([e for e in events if e.get('event') == 'promote'])
scrapes = len([e for e in events if e.get('event') == 'scrape'])
report.append(f"- Total deploys: {deploys}")
report.append(f"- Total promotes: {promotes}")
report.append(f"- Total status scrapes: {scrapes}")

output = "\n".join(report)
with open("audit_report.md", "w") as f:
    f.write(output)

print(output)
PY

    echo ""
    echo "✓ audit_report.md generated"
}

# ── router ────────────────────────────────────────────────────────────────────

case "${1:-}" in
    init)     cmd_init ;;
    validate) cmd_validate ;;
    deploy)   cmd_deploy ;;
    promote)  cmd_promote "${2:-}" ;;
    teardown) cmd_teardown "${2:-}" ;;
    status)   cmd_status ;;
    audit)    cmd_audit ;;
    *)
        echo "Usage: ./swiftdeploy [init|validate|deploy|promote|teardown|status|audit]"
        exit 1
        ;;
esac
